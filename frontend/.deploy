#!/bin/bash
set -e

# Enhanced Cloud Run Deployment Script for Mahindra Data Science Agent (Frontend)
# Version: 5.0.4-org-policy-fix

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# --- CONFIGURATION ---
SERVICE_NAME="data-science-agent-frontend"
REGION="asia-south1"
PROJECT_ID="mahindra-datalake-prod-625956"
REPO_NAME="mahindra-apps"
IMAGE_TAG="latest"

# ⚠️ Backend URL (Used during build)
BACKEND_API_URL="https://data-science-agent-scm-398184046346.asia-south1.run.app" 

# Image URI
IMAGE_URI="${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPO_NAME}/${SERVICE_NAME}:${IMAGE_TAG}"

VPC_CONNECTOR="projects/host-project-prod-env-mum/locations/asia-south1/connectors/serverless-vpc-connector"

echo -e "${BLUE}🚀 Deploying Mahindra Data Science Agent FRONTEND...${NC}"
echo -e "${BLUE}📍 Region: ${REGION}${NC}"
echo -e "${BLUE}🔗 Backend: ${BACKEND_API_URL}${NC}"

# Validation functions
check_prerequisites() {
    echo -e "${YELLOW}🔍 Checking prerequisites...${NC}"
    if ! command -v gcloud &> /dev/null; then
        echo -e "${RED}❌ gcloud CLI is not installed.${NC}"
        exit 1
    fi
    if [ ! -f "cloudbuild.yaml" ]; then
        echo -e "${RED}❌ cloudbuild.yaml not found.${NC}"
        exit 1
    fi
    if [ ! -f "Dockerfile" ]; then
        echo -e "${RED}❌ Dockerfile not found.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Prerequisites check passed${NC}"
}

setup_gcloud() {
    gcloud config set project $PROJECT_ID
}

enable_apis() {
    echo -e "${YELLOW}🔧 Enabling required APIs...${NC}"
    gcloud services enable "cloudbuild.googleapis.com" "run.googleapis.com" "artifactregistry.googleapis.com" --quiet
}

setup_artifact_registry() {
    if ! gcloud artifacts repositories describe ${REPO_NAME} --location=${REGION} &>/dev/null; then
        echo -e "${YELLOW}⚠️  Repo not found. Creating '${REPO_NAME}'...${NC}"
        gcloud artifacts repositories create ${REPO_NAME} \
            --repository-format=docker \
            --location=${REGION} \
            --description="Docker repository for Mahindra Apps"
    fi
}

# Build Container using Cloud Build
build_container() {
    echo -e "${YELLOW}🔨 Building Docker container...${NC}"
    
    gcloud builds submit \
        --config cloudbuild.yaml \
        --substitutions=_VITE_API_URL="$BACKEND_API_URL",_IMAGE_URI="$IMAGE_URI" \
        --project "$PROJECT_ID" \
        .

    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✅ Build successful${NC}"
    else
        echo -e "${RED}❌ Build failed${NC}"
        exit 1
    fi
}

# Deploy to Cloud Run
deploy_service() {
    echo -e "${YELLOW}🚢 Deploying to Cloud Run...${NC}"
    
    # FIXED: Changed ingress to 'internal-and-cloud-load-balancing' to satisfy Org Policy
    gcloud run deploy $SERVICE_NAME \
        --image "$IMAGE_URI" \
        --platform managed \
        --region $REGION \
        --project "$PROJECT_ID" \
        --allow-unauthenticated \
        --memory 16Gi \
        --cpu 8 \
        --timeout 3600 \
        --max-instances 10 \
        --min-instances 1 \
        --concurrency 10 \
        --vpc-connector $VPC_CONNECTOR \
        --port 8080 \
        --execution-environment gen2 \
        --ingress internal-and-cloud-load-balancing \
        --cpu-boost \
        --session-affinity \
        --quiet
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✅ Deployment successful!${NC}"
    else
        echo -e "${RED}❌ Deployment failed${NC}"
        exit 1
    fi
}

test_deployment() {
    echo -e "${YELLOW}🧪 Testing deployment...${NC}"
    SERVICE_URL=$(gcloud run services describe $SERVICE_NAME --region=$REGION --format="value(status.url)" 2>/dev/null)
    echo -e "${GREEN}🌐 URL: ${SERVICE_URL}${NC}"
    echo -e "${YELLOW}⚠️ Note: Since ingress is restricted, you may need to access this URL via VPN or Load Balancer.${NC}"
}

main() {
    check_prerequisites
    setup_gcloud
    enable_apis
    setup_artifact_registry
    build_container
    deploy_service
    test_deployment
}

main